{
  "manifest_version": 3,
  "name": "ProDocStore AI Editor",
  "version": "0.47.3",
  "description": "AI-first editor for GitHub-backed docs. Prompt for changes, review proposals, and use GitHub for manual edits.",
  "permissions": ["activeTab", "storage", "sidePanel", "scripting"],
  "host_permissions": [
    "https://*.pages.dev/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://api.github.com/*",
    "https://github.com/login/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Open ProDocStore AI editor"
  },
  "content_scripts": [
    {
      "matches": ["https://*.pages.dev/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
